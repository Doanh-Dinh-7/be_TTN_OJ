# Flask
SECRET_KEY=
FLASK_DEBUG=
PORT=

# Database (PostgreSQL / Supabase)
# Supabase: Settings > Database > Connection pooling > Transaction > copy URI (port 6543).
# Dùng pooler (host ...pooler.supabase.com:6543), KHÔNG dùng Direct (db.xxx.supabase.co) để tránh lỗi "Name or service not known".
DATABASE_URL=

# JWT (nên >= 32 ký tự). Access 24h, refresh 7 ngày (giây).
JWT_SECRET_KEY=
JWT_ACCESS_EXPIRES=86400
JWT_REFRESH_EXPIRES=604800

# Redis & Celery
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# CORS (comma-separated origins)
CORS_ORIGINS=

# Mail (gửi email xác thực khi đăng ký)
# Nếu không set MAIL_USERNAME/MAIL_PASSWORD, link xác thực sẽ in ra console (chế độ dev).
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@ttnoj.local
# URL frontend để tạo link xác thực trong email (vd: https://oj.example.com)
FRONTEND_URL=http://localhost:3000

# Judge (Docker)
JUDGE_MEMORY_LIMIT_MB=
JUDGE_CPU_QUOTA=
JUDGE_TIMEOUT_SECONDS=
JUDGE_NETWORK_DISABLED=
